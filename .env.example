# 이 파일을 복사해 .env 로 만들고 실제 키를 채우세요.
#   cp .env.example .env   (Windows PowerShell:  Copy-Item .env.example .env)
# Vite 에서는 반드시 VITE_ 접두사가 있어야 브라우저 코드에서 읽힙니다.

# --- Supabase (supabase.com > Project Settings > API) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- 네이버 지도 Web Dynamic Map (네이버클라우드 콘솔 > Maps > Application) ---
# 지도 표시(JS SDK)에는 Client ID 만 필요합니다.
VITE_NAVER_MAP_CLIENT_ID=
# ⚠️ Client Secret 은 여기(프론트엔드)에 넣지 마세요.
#    지오코딩/길찾기 같은 서버 REST API 를 붙일 때만, 서버 환경변수로 별도 보관합니다.
